#!/usr/bin/env bash
# cleanup-worktree - Remove a git worktree by branch, PR, or path
#
# Usage: cleanup-worktree <branch|pr-number|pr-url|worktree-path>

set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"
# shellcheck source=../lib/helpers.sh
source "$SCRIPTS_DIR/helpers.sh"

ARG="${1:?Usage: cleanup-worktree <branch|pr-number|pr-url|worktree-path>}"

# --- Resolve the worktree path ---

WT_PATH=""

# Case 1: Direct path to a worktree
if [ -d "$ARG" ] && [ -e "$ARG/.git" ]; then
  WT_PATH="$(cd "$ARG" && pwd)"
elif [ -d "$WORKTREES_BASE/$ARG" ] && [ -e "$WORKTREES_BASE/$ARG/.git" ]; then
  WT_PATH="$WORKTREES_BASE/$ARG"
fi

# Case 2: PR number or URL
if [ -z "$WT_PATH" ]; then
  PR_NUMBER=""
  if [[ "$ARG" == *github.com* ]]; then
    PR_NUMBER="$(echo "$ARG" | grep -o '[0-9]*$' || true)"
  elif [[ "$ARG" =~ ^[0-9]+$ ]]; then
    PR_NUMBER="$ARG"
  fi

  if [ -n "$PR_NUMBER" ]; then
    # Search for worktrees matching this PR number
    if [ -d "$WORKTREES_BASE" ]; then
      while IFS= read -r candidate; do
        if [ -d "$candidate" ]; then
          WT_PATH="$candidate"
          break
        fi
      done < <(find "$WORKTREES_BASE" -maxdepth 1 -type d -name "*--pr-${PR_NUMBER}-*" 2>/dev/null)
    fi
    if [ -z "$WT_PATH" ]; then
      echo "ERROR: No worktree found for PR #${PR_NUMBER}." >&2
      exit 1
    fi
  fi
fi

# Case 3: Branch name
if [ -z "$WT_PATH" ]; then
  DIR_BRANCH="$(echo "$ARG" | tr '/' '-')"
  if [ -d "$WORKTREES_BASE" ]; then
    while IFS= read -r candidate; do
      if [ -d "$candidate" ]; then
        WT_PATH="$candidate"
        break
      fi
    done < <(find "$WORKTREES_BASE" -maxdepth 1 -type d -name "*--${DIR_BRANCH}" 2>/dev/null)
  fi
  if [ -z "$WT_PATH" ]; then
    # Also check git worktree list for the branch
    EXISTING_WT="$(git worktree list --porcelain 2>/dev/null | awk -v branch="$ARG" '
      /^worktree / { wt = $0; sub(/^worktree /, "", wt) }
      /^branch refs\/heads\// {
        b = $0; sub(/^branch refs\/heads\//, "", b)
        if (b == branch) { print wt; exit }
      }
    ')"
    if [ -n "$EXISTING_WT" ]; then
      WT_PATH="$EXISTING_WT"
    fi
  fi
  if [ -z "$WT_PATH" ]; then
    echo "ERROR: No worktree found for branch '${ARG}'." >&2
    exit 1
  fi
fi

# --- Confirm and clean up ---

echo "Found worktree:"
echo "  $WT_PATH"

# Show status if the worktree is valid
if [ -e "$WT_PATH/.git" ]; then
  changes="$(git -C "$WT_PATH" status --porcelain 2>/dev/null || true)"
  if [ -n "$changes" ]; then
    echo ""
    echo "WARNING: Worktree has uncommitted changes:"
    echo "$changes"
  fi
fi

if ! prompt_yn "Remove this worktree?"; then
  echo "Aborted."
  exit 0
fi

remove_worktree "$WT_PATH"
echo "Worktree removed."
git worktree prune 2>/dev/null
