#!/usr/bin/env bash
# branch-worktree.sh - Set up a git worktree for a new branch and open it in an editor
#
# Usage: branch-worktree.sh <branch-name>

set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"
# shellcheck source=../lib/helpers.sh
source "$SCRIPTS_DIR/helpers.sh"

BRANCH_NAME="${1:?Usage: branch-worktree.sh <branch-name>}"

# Trim whitespace
BRANCH_NAME="$(echo "$BRANCH_NAME" | xargs)"
if [ -z "$BRANCH_NAME" ]; then
  echo "ERROR: Please provide a branch name." >&2
  exit 1
fi

# --- Phase 1: Set Up Worktree ---

resolve_repo_root || exit 1
cd "$REPO_ROOT"
REPO_NAME="$(basename "$REPO_ROOT")"
DIR_BRANCH="$(echo "$BRANCH_NAME" | tr '/' '-')"
WORKTREE_NAME="${REPO_NAME}--${DIR_BRANCH}"
WORKTREE_ABS="${WORKTREES_BASE}/${WORKTREE_NAME}"

echo "Branch:   ${BRANCH_NAME}"
echo "Worktree: ${WORKTREE_ABS}"

# Ensure worktrees directory exists
mkdir -p "$WORKTREES_BASE"

# Run worktree-ensure
echo ""
if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" branch "$WORKTREE_ABS" "$BRANCH_NAME" 2>&1)"; then
  MSG="$(echo "$RESULT" | parse_json message)"
  echo "ERROR: Failed to create worktree." >&2
  [ -n "$MSG" ] && echo "  $MSG" >&2
  exit 1
fi

STATUS="$(echo "$RESULT" | parse_json status)"
WT_PATH="$(echo "$RESULT" | parse_json path)"

if [ -z "$STATUS" ]; then
  echo "ERROR: Unexpected output from worktree-ensure: $RESULT" >&2
  exit 1
fi

case "$STATUS" in
  created)
    echo "Worktree created at: ${WT_PATH}"
    ;;
  exists)
    echo "Worktree already exists at: ${WT_PATH}"
    CHOICE="$(prompt_choice "What would you like to do?" "Reuse existing worktree" "Recreate from scratch")"
    if [ "$CHOICE" = "Recreate from scratch" ]; then
      git worktree remove "$WT_PATH" --force
      RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" branch "$WORKTREE_ABS" "$BRANCH_NAME" 2>&1)"
      WT_PATH="$(echo "$RESULT" | parse_json path)"
      echo "Worktree recreated at: ${WT_PATH}"
    fi
    ;;
  exists-elsewhere)
    echo "Branch '${BRANCH_NAME}' is already checked out in a worktree at:"
    echo "  ${WT_PATH}"
    CHOICE="$(prompt_choice "What would you like to do?" "Reuse existing worktree" "Move to new location (${WORKTREE_ABS})")"
    if [ "$CHOICE" != "Reuse existing worktree" ]; then
      echo "Removing old worktree..."
      git worktree remove "$WT_PATH" --force
      if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" branch "$WORKTREE_ABS" "$BRANCH_NAME" 2>&1)"; then
        MSG="$(echo "$RESULT" | parse_json message)"
        echo "ERROR: Failed to recreate worktree." >&2
        [ -n "$MSG" ] && echo "  $MSG" >&2
        exit 1
      fi
      WT_PATH="$(echo "$RESULT" | parse_json path)"
      echo "Worktree recreated at: ${WT_PATH}"
    fi
    ;;
  error)
    MSG="$(echo "$RESULT" | parse_json message)"
    echo "ERROR: Failed to create worktree." >&2
    [ -n "$MSG" ] && echo "  $MSG" >&2
    exit 1
    ;;
  *)
    echo "ERROR: Unexpected status '${STATUS}' from worktree-ensure." >&2
    exit 1
    ;;
esac

# --- Phase 2: Copy Gitignored Files ---

COPIED_GITIGNORED=false
echo "Checking size of gitignored files..."
SIZES_OUTPUT="$("$SCRIPTS_DIR/gitignored-sizes.sh" "$REPO_ROOT")"
if [ -n "$SIZES_OUTPUT" ]; then
  echo ""
  echo "Gitignored files in main worktree: ${SIZES_OUTPUT}"
  if prompt_yn "Copy these to the new worktree?"; then
    "$SCRIPTS_DIR/copy-gitignored.sh" "$REPO_ROOT" "$WT_PATH"
    COPIED_GITIGNORED=true
  fi
fi

# --- Phase 3: Detect Editor and Open ---

echo ""
EDITOR_CMD=""
if [ -n "${CURSOR_CHANNEL:-}" ] || [[ "${__CFBundleIdentifier:-}" == *cursor* ]]; then
  EDITOR_CMD="cursor"
  echo "Detected editor: Cursor"
elif [ -n "${VSCODE_PID:-}" ] || [ "${TERM_PROGRAM:-}" = "vscode" ]; then
  EDITOR_CMD="code"
  echo "Detected editor: VS Code"
fi

if [ -n "$EDITOR_CMD" ]; then
  env -u CLAUDECODE $EDITOR_CMD --new-window "$WT_PATH"
  echo "Opened new ${EDITOR_CMD} window."
else
  echo "No editor detected. You can open the worktree with:"
  echo "  env -u CLAUDECODE code --new-window ${WT_PATH}"
  echo "  env -u CLAUDECODE cursor --new-window ${WT_PATH}"
  echo "  cd ${WT_PATH}"
  if prompt_yn "Would you like to open an editor?"; then
    CHOICE="$(prompt_choice "Which editor?" "VS Code" "Cursor")"
    case "$CHOICE" in
      "VS Code") env -u CLAUDECODE code --new-window "$WT_PATH" ;;
      "Cursor") env -u CLAUDECODE cursor --new-window "$WT_PATH" ;;
    esac
  fi
fi

# --- Phase 4: Detect Dependencies ---

DEP_CMD=""
DEP_SOURCE=""

for doc in README.md README.rst README.txt README CONTRIBUTING.md DEVELOPING.md DEVELOPMENT.md SETUP.md; do
  if [ -f "$WT_PATH/$doc" ]; then
    if grep -qiE '^#{1,3}\s*(getting started|installation|setup|development|prerequisites|building)' "$WT_PATH/$doc" 2>/dev/null; then
      DEP_SOURCE="$doc"
      break
    fi
  fi
done

if [ -z "$DEP_CMD" ] && [ -f "$WT_PATH/Makefile" ] || [ -f "$WT_PATH/makefile" ]; then
  MAKEFILE="$WT_PATH/Makefile"
  [ -f "$MAKEFILE" ] || MAKEFILE="$WT_PATH/makefile"
  if [ -f "$MAKEFILE" ]; then
    for target in install setup deps dependencies init bootstrap; do
      if grep -q "^${target}:" "$MAKEFILE" 2>/dev/null; then
        DEP_CMD="make $target"
        DEP_SOURCE="Makefile"
        break
      fi
    done
  fi
fi

if [ -z "$DEP_CMD" ]; then
  if [ -f "$WT_PATH/package-lock.json" ]; then DEP_CMD="npm ci"
  elif [ -f "$WT_PATH/yarn.lock" ]; then DEP_CMD="yarn install"
  elif [ -f "$WT_PATH/pnpm-lock.yaml" ]; then DEP_CMD="pnpm install"
  elif [ -f "$WT_PATH/package.json" ]; then DEP_CMD="npm install"
  elif [ -f "$WT_PATH/requirements.txt" ]; then DEP_CMD="pip install -r requirements.txt"
  elif [ -f "$WT_PATH/Pipfile.lock" ]; then DEP_CMD="pipenv install"
  elif [ -f "$WT_PATH/poetry.lock" ]; then DEP_CMD="poetry install"
  elif [ -f "$WT_PATH/pyproject.toml" ]; then DEP_CMD="pip install -e ."
  elif [ -f "$WT_PATH/go.mod" ]; then DEP_CMD="go mod download"
  elif [ -f "$WT_PATH/Gemfile.lock" ]; then DEP_CMD="bundle install"
  elif [ -f "$WT_PATH/Cargo.lock" ]; then DEP_CMD="cargo fetch"
  elif [ -f "$WT_PATH/composer.lock" ]; then DEP_CMD="composer install"
  fi
fi

# --- Post-Setup Summary ---

echo ""
echo "============================================"
echo "Branch Worktree Ready!"
echo "============================================"
echo ""
echo "Branch:    ${BRANCH_NAME}"
echo "Worktree:  ${WT_PATH}"
echo ""

if $COPIED_GITIGNORED; then
  echo "Dependencies were copied from the main worktree."
  echo "If this branch will change dependencies, you may still need to run:"
  if [ -n "$DEP_CMD" ]; then
    echo "  cd ${WT_PATH} && ${DEP_CMD}"
  fi
else
  if [ -n "$DEP_CMD" ]; then
    echo "To install dependencies:"
    echo "  cd ${WT_PATH} && ${DEP_CMD}"
    if [ -n "$DEP_SOURCE" ]; then
      echo "  (found in ${DEP_SOURCE})"
    fi
  else
    echo "No dependency manager detected."
  fi
fi

echo ""
echo "Cleanup when done:"
echo "  git -C ${REPO_ROOT} worktree remove ${WORKTREE_ABS}"
echo "  Or list all: git -C ${REPO_ROOT} worktree list"
