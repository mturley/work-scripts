#!/usr/bin/env bash
# code-windows - List and focus VS Code windows using fzf
#
# Usage: code-windows
#   Lists all open VS Code windows and lets you pick one to focus.

set -euo pipefail

if [ "$(uname)" != "Darwin" ]; then
  echo "code-windows requires macOS (uses AppleScript to manage windows)." >&2
  exit 1
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "code-windows requires fzf. Install it with: brew install fzf" >&2
  exit 1
fi

result=$(osascript -e 'tell application "System Events" to get name of every window of (first process whose name is "Code")' 2>&1) || {
  if echo "$result" | grep -q "assistive access"; then
    echo "code-windows needs accessibility permissions." >&2
    echo "Go to System Settings > Privacy & Security > Accessibility and enable your terminal app." >&2
  else
    echo "No VS Code windows found (is VS Code running?)" >&2
  fi
  exit 1
}
windows="$result"

selected=$(echo "$windows" | tr ',' '\n' | sed 's/^ //' | fzf --prompt="VS Code window> ") || exit 0

osascript -e "tell application \"System Events\"
  set frontmost of (first process whose name is \"Code\") to true
  tell (first process whose name is \"Code\")
    perform action \"AXRaise\" of (first window whose name is \"$selected\")
  end tell
end tell"
