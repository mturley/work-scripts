#!/usr/bin/env bash
# pr-worktree.sh - Set up a git worktree for a PR and open it in an editor
#
# Usage: pr-worktree.sh <pr-number|branch|url>

set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"
# shellcheck source=../lib/helpers.sh
source "$SCRIPTS_DIR/helpers.sh"

ARGUMENTS="${1:?Usage: pr-worktree.sh <pr-number|branch|url>}"

# --- Phase 1: Find or Verify Repository ---

TARGET_OWNER=""
TARGET_REPO=""
PR_REF="$ARGUMENTS"

if [[ "$ARGUMENTS" == *github.com* ]]; then
  # Parse owner/repo and PR number from URL
  # Handles: github.com/owner/repo/pull/123
  url_path="${ARGUMENTS#*github.com/}"
  TARGET_OWNER="$(echo "$url_path" | cut -d/ -f1)"
  TARGET_REPO="$(echo "$url_path" | cut -d/ -f2)"
  PR_REF="$(echo "$url_path" | grep -o '[0-9]*$' || true)"
  if [ -z "$PR_REF" ]; then
    echo "ERROR: Could not parse PR number from URL: $ARGUMENTS" >&2
    exit 1
  fi
fi

# Check if we're in the right git repo
IN_GIT_REPO=false
if git rev-parse --is-inside-work-tree &>/dev/null; then
  IN_GIT_REPO=true
fi

if [ -n "$TARGET_OWNER" ] && [ -n "$TARGET_REPO" ]; then
  FULL_TARGET="${TARGET_OWNER}/${TARGET_REPO}"

  if $IN_GIT_REPO; then
    # If we're in a workspace with nested repos, find the matching one
    resolve_repo_root || exit 1
    cd "$REPO_ROOT"
    CURRENT_REPO="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true)"
    if [ "$CURRENT_REPO" != "$FULL_TARGET" ]; then
      IN_GIT_REPO=false
    fi
  fi

  if ! $IN_GIT_REPO; then
    echo "Not in the ${FULL_TARGET} repo. Searching for a local clone..."
    FOUND=""
    while IFS= read -r candidate; do
      if git -C "$candidate" remote -v 2>/dev/null | grep -q "${TARGET_OWNER}/${TARGET_REPO}"; then
        FOUND="$candidate"
        break
      fi
    done < <(find ~/ -maxdepth 4 -type d -name "$TARGET_REPO" -not -path "*/node_modules/*" -not -path "*/.claude/worktrees/*" -not -path "*/.worktrees/*" 2>/dev/null)

    if [ -z "$FOUND" ]; then
      echo "ERROR: No local clone of ${FULL_TARGET} found." >&2
      exit 1
    fi
    echo "Found local clone at: $FOUND"
    cd "$FOUND"
  fi
else
  # No URL provided — resolve which repo to use
  resolve_repo_root || exit 1
  cd "$REPO_ROOT"
fi

# Get PR info
echo "Fetching PR #${PR_REF} info..."
PR_JSON="$(gh pr view "$PR_REF" --json number,title,url)"
PR_NUMBER="$(echo "$PR_JSON" | parse_json number)"
PR_TITLE="$(echo "$PR_JSON" | parse_json title)"
PR_URL="$(echo "$PR_JSON" | parse_json url)"

# Generate slug from title
SLUG="$(echo "$PR_TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40 | sed 's/-$//')"
WORKTREE_NAME="pr-${PR_NUMBER}-${SLUG}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BASE_REPO="$(gh repo view --json nameWithOwner --jq '.nameWithOwner')"
REPO_NAME="$(basename "$REPO_ROOT")"
WORKTREE_ABS="${WORKTREES_BASE}/${REPO_NAME}--${WORKTREE_NAME}"

echo "PR #${PR_NUMBER}: ${PR_TITLE}"
echo "Worktree: ${WORKTREE_ABS}"

# Ensure worktrees directory exists
mkdir -p "$WORKTREES_BASE"

# Run worktree-ensure
echo ""
if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"; then
  MSG="$(echo "$RESULT" | parse_json message)"
  echo "ERROR: Failed to create worktree." >&2
  [ -n "$MSG" ] && echo "  $MSG" >&2
  exit 1
fi

STATUS="$(echo "$RESULT" | parse_json status)"
WT_PATH="$(echo "$RESULT" | parse_json path)"

if [ -z "$STATUS" ]; then
  echo "ERROR: Unexpected output from worktree-ensure: $RESULT" >&2
  exit 1
fi

case "$STATUS" in
  created)
    echo "Worktree created at: ${WT_PATH}"
    ;;
  exists)
    echo "Worktree already exists and is up to date."
    CHOICE="$(prompt_choice "What would you like to do?" "Reuse existing worktree" "Recreate from scratch")"
    if [ "$CHOICE" = "Recreate from scratch" ]; then
      PR_BRANCH="review/pr-${PR_NUMBER}-${SLUG}"
      remove_worktree "$WT_PATH"
      git branch -D "$PR_BRANCH" 2>/dev/null || true
      RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"
      WT_PATH="$(echo "$RESULT" | parse_json path)"
      echo "Worktree recreated at: ${WT_PATH}"
    fi
    ;;
  exists-outdated)
    LOCAL_HEAD="$(echo "$RESULT" | parse_json local_head)"
    REMOTE_HEAD="$(echo "$RESULT" | parse_json remote_head)"
    echo "Worktree exists but is behind the PR's latest changes."
    echo "  Local:  ${LOCAL_HEAD:0:12}"
    echo "  Remote: ${REMOTE_HEAD:0:12}"
    CHOICE="$(prompt_choice "What would you like to do?" "Update to latest" "Recreate from scratch" "Reuse as-is")"
    case "$CHOICE" in
      "Update to latest")
        PR_BRANCH="review/pr-${PR_NUMBER}-${SLUG}"
        git fetch "https://github.com/${BASE_REPO}.git" "refs/pull/${PR_NUMBER}/head:${PR_BRANCH}" --force
        git -C "$WT_PATH" reset --hard "$PR_BRANCH"
        echo "Updated to latest PR state."
        ;;
      "Recreate from scratch")
        PR_BRANCH="review/pr-${PR_NUMBER}-${SLUG}"
        remove_worktree "$WT_PATH"
        git branch -D "$PR_BRANCH" 2>/dev/null || true
        RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"
        WT_PATH="$(echo "$RESULT" | parse_json path)"
        echo "Worktree recreated at: ${WT_PATH}"
        ;;
      "Reuse as-is")
        echo "Keeping worktree as-is."
        ;;
    esac
    ;;
  error)
    MSG="$(echo "$RESULT" | parse_json message)"
    echo "ERROR: Failed to create worktree." >&2
    [ -n "$MSG" ] && echo "  $MSG" >&2
    exit 1
    ;;
  *)
    echo "ERROR: Unexpected status '${STATUS}' from worktree-ensure." >&2
    exit 1
    ;;
esac

# --- Phase 2: Copy Gitignored Files ---

COPIED_FILES=false
if copy_worktree_files "$SCRIPTS_DIR" "$REPO_ROOT" "$WT_PATH"; then
  COPIED_FILES=true
fi

# --- Phase 3: Detect Editor and Open ---

echo ""
detect_editor
open_editor "$WT_PATH"

# --- Post-Setup Summary ---

echo ""
echo "============================================"
echo "PR Worktree Ready!"
echo "============================================"
echo ""
echo "PR:        #${PR_NUMBER} - ${PR_TITLE}"
echo "URL:       ${PR_URL}"
echo "Worktree:  ${WT_PATH}"

worktree_repl "$REPO_ROOT" "$WT_PATH"
