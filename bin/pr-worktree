#!/usr/bin/env bash
# pr-worktree.sh - Set up a git worktree for a PR and open it in an editor
#
# Usage: pr-worktree.sh <pr-number|branch|url>

set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"
# shellcheck source=../lib/helpers.sh
source "$SCRIPTS_DIR/helpers.sh"

ARGUMENTS="${1:?Usage: pr-worktree.sh <pr-number|branch|url>}"

# --- Phase 1: Find or Verify Repository ---

TARGET_OWNER=""
TARGET_REPO=""
PR_REF="$ARGUMENTS"

if [[ "$ARGUMENTS" == *github.com* ]]; then
  # Parse owner/repo and PR number from URL
  # Handles: github.com/owner/repo/pull/123
  url_path="${ARGUMENTS#*github.com/}"
  TARGET_OWNER="$(echo "$url_path" | cut -d/ -f1)"
  TARGET_REPO="$(echo "$url_path" | cut -d/ -f2)"
  PR_REF="$(echo "$url_path" | grep -o '[0-9]*$' || true)"
  if [ -z "$PR_REF" ]; then
    echo "ERROR: Could not parse PR number from URL: $ARGUMENTS" >&2
    exit 1
  fi
fi

# Check if we're in the right git repo
IN_GIT_REPO=false
if git rev-parse --is-inside-work-tree &>/dev/null; then
  IN_GIT_REPO=true
fi

if [ -n "$TARGET_OWNER" ] && [ -n "$TARGET_REPO" ]; then
  FULL_TARGET="${TARGET_OWNER}/${TARGET_REPO}"

  if $IN_GIT_REPO; then
    # If we're in a workspace with nested repos, find the matching one
    resolve_repo_root || exit 1
    cd "$REPO_ROOT"
    CURRENT_REPO="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true)"
    if [ "$CURRENT_REPO" != "$FULL_TARGET" ]; then
      IN_GIT_REPO=false
    fi
  fi

  if ! $IN_GIT_REPO; then
    echo "Not in the ${FULL_TARGET} repo. Searching for a local clone..."
    FOUND=""
    while IFS= read -r candidate; do
      if git -C "$candidate" remote -v 2>/dev/null | grep -q "${TARGET_OWNER}/${TARGET_REPO}"; then
        FOUND="$candidate"
        break
      fi
    done < <(find ~/ -maxdepth 4 -type d -name "$TARGET_REPO" -not -path "*/node_modules/*" -not -path "*/.claude/worktrees/*" -not -path "*/.worktrees/*" 2>/dev/null)

    if [ -z "$FOUND" ]; then
      echo "ERROR: No local clone of ${FULL_TARGET} found." >&2
      exit 1
    fi
    echo "Found local clone at: $FOUND"
    cd "$FOUND"
  fi
else
  # No URL provided — resolve which repo to use
  resolve_repo_root || exit 1
  cd "$REPO_ROOT"
fi

# Get PR info
echo "Fetching PR #${PR_REF} info..."
PR_JSON="$(gh pr view "$PR_REF" --json number,title,url)"
PR_NUMBER="$(echo "$PR_JSON" | parse_json number)"
PR_TITLE="$(echo "$PR_JSON" | parse_json title)"
PR_URL="$(echo "$PR_JSON" | parse_json url)"

# Generate slug from title
SLUG="$(echo "$PR_TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40 | sed 's/-$//')"
WORKTREE_NAME="pr-${PR_NUMBER}-${SLUG}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BASE_REPO="$(gh repo view --json nameWithOwner --jq '.nameWithOwner')"
REPO_NAME="$(basename "$REPO_ROOT")"
WORKTREE_ABS="${WORKTREES_BASE}/${REPO_NAME}--${WORKTREE_NAME}"

echo "PR #${PR_NUMBER}: ${PR_TITLE}"
echo "Worktree: ${WORKTREE_ABS}"

# Ensure worktrees directory exists
mkdir -p "$WORKTREES_BASE"

# Run worktree-ensure
echo ""
if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"; then
  MSG="$(echo "$RESULT" | parse_json message)"
  echo "ERROR: Failed to create worktree." >&2
  [ -n "$MSG" ] && echo "  $MSG" >&2
  exit 1
fi

STATUS="$(echo "$RESULT" | parse_json status)"
WT_PATH="$(echo "$RESULT" | parse_json path)"

if [ -z "$STATUS" ]; then
  echo "ERROR: Unexpected output from worktree-ensure: $RESULT" >&2
  exit 1
fi

case "$STATUS" in
  created)
    echo "Worktree created at: ${WT_PATH}"
    ;;
  exists)
    echo "Worktree already exists and is up to date."
    CHOICE="$(prompt_choice "What would you like to do?" "Reuse existing worktree" "Recreate from scratch")"
    if [ "$CHOICE" = "Recreate from scratch" ]; then
      git worktree remove "$WT_PATH" --force
      RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"
      WT_PATH="$(echo "$RESULT" | parse_json path)"
      echo "Worktree recreated at: ${WT_PATH}"
    fi
    ;;
  exists-outdated)
    LOCAL_HEAD="$(echo "$RESULT" | parse_json local_head)"
    REMOTE_HEAD="$(echo "$RESULT" | parse_json remote_head)"
    echo "Worktree exists but is behind the PR's latest changes."
    echo "  Local:  ${LOCAL_HEAD:0:12}"
    echo "  Remote: ${REMOTE_HEAD:0:12}"
    CHOICE="$(prompt_choice "What would you like to do?" "Update to latest" "Recreate from scratch" "Reuse as-is")"
    case "$CHOICE" in
      "Update to latest")
        BRANCH_NAME="review/pr-${PR_NUMBER}-${SLUG}"
        git fetch "https://github.com/${BASE_REPO}.git" "refs/pull/${PR_NUMBER}/head:${BRANCH_NAME}" --force
        git -C "$WT_PATH" reset --hard "$BRANCH_NAME"
        echo "Updated to latest PR state."
        ;;
      "Recreate from scratch")
        git worktree remove "$WT_PATH" --force
        RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"
        WT_PATH="$(echo "$RESULT" | parse_json path)"
        echo "Worktree recreated at: ${WT_PATH}"
        ;;
      "Reuse as-is")
        echo "Keeping worktree as-is."
        ;;
    esac
    ;;
  error)
    MSG="$(echo "$RESULT" | parse_json message)"
    echo "ERROR: Failed to create worktree." >&2
    [ -n "$MSG" ] && echo "  $MSG" >&2
    exit 1
    ;;
  *)
    echo "ERROR: Unexpected status '${STATUS}' from worktree-ensure." >&2
    exit 1
    ;;
esac

# --- Phase 2: Copy Gitignored Files ---

COPIED_GITIGNORED=false
SIZES_OUTPUT="$("$SCRIPTS_DIR/gitignored-sizes.sh" "$REPO_ROOT")"
if [ -n "$SIZES_OUTPUT" ]; then
  echo ""
  echo "Gitignored files in main worktree:"
  echo "$SIZES_OUTPUT"
  if prompt_yn "Copy these to the new worktree?"; then
    "$SCRIPTS_DIR/copy-gitignored.sh" "$REPO_ROOT" "$WT_PATH"
    COPIED_GITIGNORED=true
  fi
fi

# --- Phase 3: Detect Editor and Open ---

echo ""
EDITOR_CMD=""
if [ -n "${CURSOR_CHANNEL:-}" ] || [[ "${__CFBundleIdentifier:-}" == *cursor* ]]; then
  EDITOR_CMD="cursor"
  echo "Detected editor: Cursor"
elif [ -n "${VSCODE_PID:-}" ] || [ "${TERM_PROGRAM:-}" = "vscode" ]; then
  EDITOR_CMD="code"
  echo "Detected editor: VS Code"
fi

if [ -n "$EDITOR_CMD" ]; then
  env -u CLAUDECODE $EDITOR_CMD --new-window "$WT_PATH"
  echo "Opened new ${EDITOR_CMD} window."
else
  echo "No editor detected. You can open the worktree with:"
  echo "  env -u CLAUDECODE code --new-window ${WT_PATH}"
  echo "  env -u CLAUDECODE cursor --new-window ${WT_PATH}"
  echo "  cd ${WT_PATH}"
  if prompt_yn "Would you like to open an editor?"; then
    CHOICE="$(prompt_choice "Which editor?" "VS Code" "Cursor")"
    case "$CHOICE" in
      "VS Code") env -u CLAUDECODE code --new-window "$WT_PATH" ;;
      "Cursor") env -u CLAUDECODE cursor --new-window "$WT_PATH" ;;
    esac
  fi
fi

# --- Phase 4: Detect Dependencies ---

DEP_CMD=""
DEP_SOURCE=""

# Check documentation files for setup instructions
for doc in README.md README.rst README.txt README CONTRIBUTING.md DEVELOPING.md DEVELOPMENT.md SETUP.md; do
  if [ -f "$WT_PATH/$doc" ]; then
    # Look for setup/install sections
    if grep -qiE '^#{1,3}\s*(getting started|installation|setup|development|prerequisites|building)' "$WT_PATH/$doc" 2>/dev/null; then
      DEP_SOURCE="$doc"
      break
    fi
  fi
done

# Check Makefile for common targets
if [ -z "$DEP_CMD" ] && [ -f "$WT_PATH/Makefile" ] || [ -f "$WT_PATH/makefile" ]; then
  MAKEFILE="$WT_PATH/Makefile"
  [ -f "$MAKEFILE" ] || MAKEFILE="$WT_PATH/makefile"
  if [ -f "$MAKEFILE" ]; then
    for target in install setup deps dependencies init bootstrap; do
      if grep -q "^${target}:" "$MAKEFILE" 2>/dev/null; then
        DEP_CMD="make $target"
        DEP_SOURCE="Makefile"
        break
      fi
    done
  fi
fi

# Check lockfiles/manifests
if [ -z "$DEP_CMD" ]; then
  if [ -f "$WT_PATH/package-lock.json" ]; then DEP_CMD="npm ci"
  elif [ -f "$WT_PATH/yarn.lock" ]; then DEP_CMD="yarn install"
  elif [ -f "$WT_PATH/pnpm-lock.yaml" ]; then DEP_CMD="pnpm install"
  elif [ -f "$WT_PATH/package.json" ]; then DEP_CMD="npm install"
  elif [ -f "$WT_PATH/requirements.txt" ]; then DEP_CMD="pip install -r requirements.txt"
  elif [ -f "$WT_PATH/Pipfile.lock" ]; then DEP_CMD="pipenv install"
  elif [ -f "$WT_PATH/poetry.lock" ]; then DEP_CMD="poetry install"
  elif [ -f "$WT_PATH/pyproject.toml" ]; then DEP_CMD="pip install -e ."
  elif [ -f "$WT_PATH/go.mod" ]; then DEP_CMD="go mod download"
  elif [ -f "$WT_PATH/Gemfile.lock" ]; then DEP_CMD="bundle install"
  elif [ -f "$WT_PATH/Cargo.lock" ]; then DEP_CMD="cargo fetch"
  elif [ -f "$WT_PATH/composer.lock" ]; then DEP_CMD="composer install"
  fi
fi

# --- Post-Setup Summary ---

echo ""
echo "============================================"
echo "PR Worktree Ready!"
echo "============================================"
echo ""
echo "PR:        #${PR_NUMBER} - ${PR_TITLE}"
echo "URL:       ${PR_URL}"
echo "Worktree:  ${WT_PATH}"
echo ""

if $COPIED_GITIGNORED; then
  echo "Dependencies were copied from the main worktree."
  echo "If the PR changes dependencies, you may still need to run:"
  if [ -n "$DEP_CMD" ]; then
    echo "  cd ${WT_PATH} && ${DEP_CMD}"
  fi
else
  if [ -n "$DEP_CMD" ]; then
    echo "To install dependencies:"
    echo "  cd ${WT_PATH} && ${DEP_CMD}"
    if [ -n "$DEP_SOURCE" ]; then
      echo "  (found in ${DEP_SOURCE})"
    fi
  else
    echo "No dependency manager detected."
  fi
fi

echo ""
echo "Next steps: Run /review in the new window to start the code review."
echo ""
echo "Cleanup when done:"
echo "  git -C ${REPO_ROOT} worktree remove ${WORKTREE_ABS}"
echo "  Or list all: git -C ${REPO_ROOT} worktree list"
