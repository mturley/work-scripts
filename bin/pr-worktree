#!/usr/bin/env bash
# pr-worktree.sh - Set up a git worktree for a PR and open it in an editor
#
# Usage: pr-worktree.sh <pr-number|branch|url>

set -euo pipefail

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0")")/../lib" && pwd)"
# shellcheck source=../lib/helpers.sh
source "$SCRIPTS_DIR/helpers.sh"

ARGUMENTS="${1:?Usage: pr-worktree.sh <pr-number|branch|url>}"

# --- Phase 1: Find or Verify Repository ---

TARGET_OWNER=""
TARGET_REPO=""
PR_REF="$ARGUMENTS"

if [[ "$ARGUMENTS" == *github.com* ]]; then
  # Parse owner/repo and PR number from URL
  # Handles: github.com/owner/repo/pull/123
  url_path="${ARGUMENTS#*github.com/}"
  TARGET_OWNER="$(echo "$url_path" | cut -d/ -f1)"
  TARGET_REPO="$(echo "$url_path" | cut -d/ -f2)"
  PR_REF="$(echo "$url_path" | grep -o '[0-9]*$' || true)"
  if [ -z "$PR_REF" ]; then
    echo "ERROR: Could not parse PR number from URL: $ARGUMENTS" >&2
    exit 1
  fi
fi

# Check if we're in the right git repo
IN_GIT_REPO=false
if git rev-parse --is-inside-work-tree &>/dev/null; then
  IN_GIT_REPO=true
fi

repo_matches_target() {
  git -C "$1" remote -v 2>/dev/null | grep -q "$2"
}

if [ -n "$TARGET_OWNER" ] && [ -n "$TARGET_REPO" ]; then
  FULL_TARGET="${TARGET_OWNER}/${TARGET_REPO}"
  FOUND=""

  if $IN_GIT_REPO; then
    toplevel="$(git rev-parse --show-toplevel)"
    if repo_matches_target "$toplevel" "$FULL_TARGET"; then
      FOUND="$toplevel"
    else
      # Search nested repos within current workspace
      while IFS= read -r gitdir; do
        candidate="$(dirname "$gitdir")"
        [ "$candidate" = "$toplevel" ] && continue
        if repo_matches_target "$candidate" "$FULL_TARGET"; then
          FOUND="$candidate"
          break
        fi
      done < <(find "$toplevel" -maxdepth 4 -name .git -not -path "*/.worktrees/*" -not -path "*/node_modules/*" -not -path "*/.claude/*" 2>/dev/null | sort)
    fi
  fi

  if [ -z "$FOUND" ]; then
    echo "Not in the ${FULL_TARGET} repo. Searching for a local clone..."
    while IFS= read -r candidate; do
      if repo_matches_target "$candidate" "$FULL_TARGET"; then
        FOUND="$candidate"
        break
      fi
    done < <(find ~/ -maxdepth 4 -type d -name "$TARGET_REPO" -not -path "*/node_modules/*" -not -path "*/.claude/worktrees/*" -not -path "*/.worktrees/*" 2>/dev/null)
  fi

  if [ -z "$FOUND" ]; then
    echo "ERROR: No local clone of ${FULL_TARGET} found." >&2
    exit 1
  fi
  echo "Using repo: $FOUND"
  cd "$FOUND"
else
  # No URL provided — resolve which repo to use
  resolve_repo_root || exit 1
  cd "$REPO_ROOT"
fi

# Get PR info
echo "Fetching PR #${PR_REF} info..."
PR_JSON="$(gh pr view "$PR_REF" --json number,title,url,headRefName,headRepositoryOwner)"
PR_NUMBER="$(echo "$PR_JSON" | parse_json number)"
PR_TITLE="$(echo "$PR_JSON" | parse_json title)"
PR_URL="$(echo "$PR_JSON" | parse_json url)"
PR_HEAD_REF="$(echo "$PR_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('headRefName',''))")"
PR_HEAD_OWNER="$(echo "$PR_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin).get('headRepositoryOwner',{}).get('login',''))")"

# Generate slug from title
SLUG="$(echo "$PR_TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//' | cut -c1-40 | sed 's/-$//')"
WORKTREE_NAME="pr-${PR_NUMBER}-${SLUG}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
BASE_REPO="$(gh repo view --json nameWithOwner --jq '.nameWithOwner')"
REPO_NAME="$(basename "$REPO_ROOT")"
WORKTREE_ABS="${WORKTREES_BASE}/${REPO_NAME}--${WORKTREE_NAME}"

echo "PR #${PR_NUMBER}: ${PR_TITLE}"
echo "Worktree: ${WORKTREE_ABS}"

# Ensure worktrees directory exists
mkdir -p "$WORKTREES_BASE"

# Run worktree-ensure
echo ""
if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"; then
  MSG="$(echo "$RESULT" | parse_json message)"
  echo "ERROR: Failed to create worktree." >&2
  [ -n "$MSG" ] && echo "  $MSG" >&2
  exit 1
fi

STATUS="$(echo "$RESULT" | parse_json status)"
WT_PATH="$(echo "$RESULT" | parse_json path)"

if [ -z "$STATUS" ]; then
  echo "ERROR: Unexpected output from worktree-ensure: $RESULT" >&2
  exit 1
fi

# warn_pr_local_changes <worktree-path>
# Warns about uncommitted changes or local commits before destructive operations.
# Returns 1 if the user aborts.
warn_pr_local_changes() {
  local wt_path="$1"
  local has_warning=false

  # Check for uncommitted changes
  local changes
  changes="$(git -C "$wt_path" status --porcelain 2>/dev/null)"
  if [ -n "$changes" ]; then
    echo ""
    echo "WARNING: Worktree has uncommitted changes:"
    echo "$changes"
    has_warning=true
  fi

  if $has_warning; then
    if ! prompt_yn "Continue? These changes will be lost."; then
      return 1
    fi
  fi
  return 0
}

recreate_pr_worktree() {
  local pr_branch="review/pr-${PR_NUMBER}-${SLUG}"
  warn_pr_local_changes "$WT_PATH" || return 1
  remove_worktree "$WT_PATH"
  git branch -D "$pr_branch" 2>/dev/null || true
  if ! RESULT="$("$SCRIPTS_DIR/worktree-ensure.sh" pr "$WORKTREE_ABS" "$PR_NUMBER" "$SLUG" "$BASE_REPO" 2>&1)"; then
    MSG="$(echo "$RESULT" | parse_json message)"
    echo "ERROR: Failed to recreate worktree." >&2
    [ -n "$MSG" ] && echo "  $MSG" >&2
    return 1
  fi
  WT_PATH="$(echo "$RESULT" | parse_json path)"
  echo "Worktree recreated at: ${WT_PATH}"
}

# setup_pr_tracking <worktree-path> <local-branch> <pr-head-owner> <pr-head-ref>
# Finds the git remote matching the PR owner and sets the local branch to track it.
setup_pr_tracking() {
  local wt_path="$1" local_branch="$2" head_owner="$3" head_ref="$4"
  if [ -z "$head_owner" ] || [ -z "$head_ref" ]; then
    return 0
  fi
  # Find a remote whose URL contains the PR owner (case-insensitive)
  local remote_name=""
  while IFS= read -r line; do
    local name url
    name="$(echo "$line" | awk '{print $1}')"
    url="$(echo "$line" | awk '{print $2}')"
    # Match github.com/<owner>/ in the URL (case-insensitive)
    if echo "$url" | grep -qi "github\.com[:/]${head_owner}/"; then
      remote_name="$name"
      break
    fi
  done < <(git remote -v | grep '(fetch)')

  if [ -z "$remote_name" ]; then
    echo "Note: No git remote found for '${head_owner}'. Branch tracking not set."
    return 0
  fi

  # Fetch the PR branch from the remote
  git fetch "$remote_name" "$head_ref" 2>/dev/null || true
  # Set tracking
  git -C "$wt_path" branch --set-upstream-to="${remote_name}/${head_ref}" "$local_branch" 2>/dev/null || true
}

case "$STATUS" in
  created)
    echo "Worktree created at: ${WT_PATH}"
    ;;
  exists)
    echo "Worktree already exists and is up to date."
    CHOICE="$(prompt_choice "What would you like to do?" "Reuse existing worktree" "Recreate from scratch")"
    if [ "$CHOICE" = "Recreate from scratch" ]; then
      recreate_pr_worktree || exit 1
    fi
    ;;
  exists-outdated)
    LOCAL_HEAD="$(echo "$RESULT" | parse_json local_head)"
    REMOTE_HEAD="$(echo "$RESULT" | parse_json remote_head)"
    echo "Worktree exists but is behind the PR's latest changes."
    echo "  Local:  ${LOCAL_HEAD:0:12}"
    echo "  Remote: ${REMOTE_HEAD:0:12}"
    CHOICE="$(prompt_choice "What would you like to do?" "Update to latest" "Recreate from scratch" "Reuse as-is")"
    case "$CHOICE" in
      "Update to latest")
        warn_pr_local_changes "$WT_PATH" || exit 1
        PR_BRANCH="review/pr-${PR_NUMBER}-${SLUG}"
        git fetch "https://github.com/${BASE_REPO}.git" "refs/pull/${PR_NUMBER}/head:${PR_BRANCH}" --force
        git -C "$WT_PATH" reset --hard "$PR_BRANCH"
        echo "Updated to latest PR state."
        ;;
      "Recreate from scratch")
        recreate_pr_worktree || exit 1
        ;;
      "Reuse as-is")
        echo "Keeping worktree as-is."
        ;;
    esac
    ;;
  error)
    MSG="$(echo "$RESULT" | parse_json message)"
    echo "ERROR: Failed to create worktree." >&2
    [ -n "$MSG" ] && echo "  $MSG" >&2
    exit 1
    ;;
  *)
    echo "ERROR: Unexpected status '${STATUS}' from worktree-ensure." >&2
    exit 1
    ;;
esac

# Set up branch tracking for the PR's head remote/branch
PR_LOCAL_BRANCH="review/pr-${PR_NUMBER}-${SLUG}"
setup_pr_tracking "$WT_PATH" "$PR_LOCAL_BRANCH" "$PR_HEAD_OWNER" "$PR_HEAD_REF"

# --- Phase 2: Copy Gitignored Files ---

COPIED_FILES=false
if copy_worktree_files "$SCRIPTS_DIR" "$REPO_ROOT" "$WT_PATH"; then
  COPIED_FILES=true
fi

# --- Phase 3: Detect Editor and Open ---

echo ""
detect_editor
open_editor "$WT_PATH"

# --- Post-Setup Summary ---

echo ""
echo "============================================"
echo "PR Worktree Ready!"
echo "============================================"
echo ""
echo "PR:        #${PR_NUMBER} - ${PR_TITLE}"
echo "URL:       ${PR_URL}"
echo "Worktree:  ${WT_PATH}"

worktree_repl "$REPO_ROOT" "$WT_PATH"
