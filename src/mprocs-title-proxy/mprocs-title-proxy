#!/usr/bin/env python3
"""PTY proxy that intercepts OSC title sequences and renames the mprocs pane.

Runs a command inside a pseudo-terminal, relays all I/O transparently,
and watches the output stream for OSC 0/2 escape sequences (terminal
title updates). When one is detected, it calls mprocs --server to
rename the current process pane.

Usage: mprocs-title-proxy <command> [args...]

Requires MPROCS_SOCKET (or WORKTREE_SHELL_MPROCS_SOCK) to be set.
Falls back to running the command directly if neither is set.
"""

import os
import pty
import select
import signal
import subprocess
import sys

CHUNK_SIZE = 4096
ESC = b'\x1b'
BEL = b'\x07'
ST = b'\x1b\x5c'  # ESC backslash (alternate string terminator)


def get_mprocs_socket():
    return (os.environ.get('WORKTREE_SHELL_MPROCS_SOCK')
            or os.environ.get('MPROCS_SOCKET'))


def rename_pane(socket, title):
    title_escaped = title.replace('"', '\\"')
    try:
        subprocess.Popen(
            ['mprocs', '--server', socket, '--ctl',
             '{c: rename-proc, name: "' + title_escaped + '"}'],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
    except FileNotFoundError:
        pass


def process_output(data, buf, socket):
    """Scan data for OSC 0/2 sequences. Returns data unchanged (pass-through).

    Accumulates partial sequences in buf (a bytearray).
    """
    buf.extend(data)

    while True:
        # Look for ESC ]
        idx = buf.find(b'\x1b]')
        if idx == -1:
            # No OSC start found; keep only the last byte in case it's a
            # partial ESC at the very end
            if len(buf) > 0 and buf[-1:] == ESC:
                del buf[:-1]
            else:
                buf.clear()
            break

        # Find the terminator (BEL or ST)
        end_bel = buf.find(BEL, idx + 2)
        end_st = buf.find(ST, idx + 2)
        if end_bel == -1 and end_st == -1:
            # No terminator yet; keep from idx onward for next chunk
            del buf[:idx]
            break

        # Pick the earliest terminator
        if end_bel != -1 and (end_st == -1 or end_bel < end_st):
            end = end_bel
            term_len = 1
        else:
            end = end_st
            term_len = 2

        # Extract the OSC payload (between ESC] and terminator)
        payload = buf[idx + 2:end]
        # Consume this sequence
        del buf[:end + term_len]

        # Parse: payload is "N;title" where N is 0 or 2
        try:
            payload_str = payload.decode('utf-8', errors='replace')
        except Exception:
            continue

        if payload_str.startswith('0;') or payload_str.startswith('2;'):
            title = payload_str[2:]
            if title and socket:
                rename_pane(socket, title)

    return data


def main():
    if len(sys.argv) < 2:
        print(f'Usage: {sys.argv[0]} <command> [args...]', file=sys.stderr)
        sys.exit(1)

    socket = get_mprocs_socket()
    if not socket:
        os.execvp(sys.argv[1], sys.argv[1:])

    # Fork a child in a new PTY
    pid, master_fd = pty.fork()
    if pid == 0:
        # Child: exec the command
        os.execvp(sys.argv[1], sys.argv[1:])

    # Parent: proxy I/O between stdin/stdout and the PTY master
    # Forward SIGWINCH to the child so it sees terminal resizes
    def handle_winch(signum, frame):
        import fcntl
        import struct
        import termios
        try:
            ws = fcntl.ioctl(sys.stdin.fileno(), termios.TIOCGWINSZ,
                             b'\x00' * 8)
            fcntl.ioctl(master_fd, termios.TIOCSWINSZ, ws)
            os.kill(pid, signal.SIGWINCH)
        except (OSError, ValueError):
            pass

    signal.signal(signal.SIGWINCH, handle_winch)

    # Set initial window size
    try:
        handle_winch(None, None)
    except Exception:
        pass

    # Put stdin in raw mode
    old_settings = None
    try:
        import tty
        import termios
        old_settings = termios.tcgetattr(sys.stdin.fileno())
        tty.setraw(sys.stdin.fileno())
    except (termios.error, ValueError):
        pass

    buf = bytearray()
    exit_code = 0

    try:
        while True:
            try:
                rlist, _, _ = select.select(
                    [sys.stdin.fileno(), master_fd], [], [], 0.1)
            except (select.error, ValueError):
                break

            if sys.stdin.fileno() in rlist:
                try:
                    data = os.read(sys.stdin.fileno(), CHUNK_SIZE)
                    if not data:
                        break
                    os.write(master_fd, data)
                except OSError:
                    break

            if master_fd in rlist:
                try:
                    data = os.read(master_fd, CHUNK_SIZE)
                    if not data:
                        break
                    process_output(data, buf, socket)
                    os.write(sys.stdout.fileno(), data)
                except OSError:
                    break
    finally:
        # Restore terminal
        if old_settings is not None:
            import termios
            try:
                termios.tcsetattr(sys.stdin.fileno(), termios.TCSADRAIN,
                                  old_settings)
            except (termios.error, ValueError):
                pass

        # Wait for child and propagate exit code
        try:
            _, status = os.waitpid(pid, 0)
            if os.WIFEXITED(status):
                exit_code = os.WEXITSTATUS(status)
            elif os.WIFSIGNALED(status):
                exit_code = 128 + os.WTERMSIG(status)
        except ChildProcessError:
            pass

        os.close(master_fd)

    sys.exit(exit_code)


if __name__ == '__main__':
    main()
