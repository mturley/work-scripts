# Obsidian vault path (absolute path to the vault root directory)
OBSIDIAN_VAULT=/path/to/your/vault

# Path to a file that exports JIRA_HOST, JIRA_EMAIL, and JIRA_TOKEN
# See jira.env.example for the expected format of that file.
# Generate an API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SECRETS_ENV=~/secrets/jira.env
